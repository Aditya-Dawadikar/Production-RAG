EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

CHROMA_DIR=./local/chroma
CHROMA_COLLECTION=wiki_chunks
CHROMA_HNSW_CONSTRUCTION_EF=200
CHROMA_HNSW_SEARCH_EF=100

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=wiki_chunks

GROQ_API_KEY=your_key
GROQ_MODEL=llama-3.1-8b-instant

LLM_TEMPERATURE=0

RAG_PROMPT=rag

RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

RETRIEVAL_TOP_K=50
RERANK_TOP_K=5

LOG_LEVEL=INFO

# Setup / data population (used by setup/*.sh scripts)
S3_BUCKET=prod-rag-bucket
ES_INGEST_S3_PREFIX=wiki-chunks
ES_INGEST_BATCH_SIZE=1000
CHROMA_BACKUP_S3_PREFIX=wiki-chroma-backup

# Evals (used by evals/*.py)
EVAL_DATASET_PATH=evals/dataset/wiki_eval_dataset.json
EVAL_SAMPLE_SIZE=20
EVAL_RESULTS_DIR=evals/results
EVAL_WIKI_DATASET_DIR=../wiki_dataset/plain-text-wikipedia-simpleenglish
EVAL_UNANSWERABLE_DATASET_PATH=evals/dataset/wiki_eval_unanswerable.json
EVAL_HALLUCINATION_DATASET_PATH=evals/dataset/wiki_eval_hallucination_trap.json
EVAL_HALLUCINATION_SAMPLE_SIZE=10